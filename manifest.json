{
  "manifest_version": 3,
  "name": "Suno Slop Detector",
  "version": "0.1.0",
  "description": "Reads ONLY the lyrics box on a Suno song page and rates how much it reeks of AI cliché. For fun. And spite.",
  "permissions": ["activeTab"],
  "browser_specific_settings": {
    "gecko": {
      "id": "suno-slop-detector@local",
      "strict_min_version": "121.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://suno.com/song/*"],
      "js": ["src/slop-core.js", "src/common_words.js", "src/features.js", "src/baseline.js", "src/content.js"],
      "css": ["src/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Suno Slop Detector",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
