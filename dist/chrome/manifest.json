{
  "manifest_version": 3,
  "name": "Suno Slop Detector",
  "version": "0.2.0",
  "description": "Scores how AI a Suno song's lyrics read with a trained model, plus craft feedback. Reads only the lyrics box. For fun. And spite.",
  "permissions": [
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://suno.com/song/*"
      ],
      "js": [
        "src/slop-core.js",
        "src/common_words.js",
        "src/features.js",
        "src/ext/patterns.browser.js",
        "src/ext/tier3.browser.js",
        "src/ext/model.js",
        "src/ext/clean-lyrics.js",
        "src/ext/v2-engine.js",
        "src/ext/v2-panel.js",
        "src/content.js"
      ],
      "css": [
        "src/overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Suno Slop Detector",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}